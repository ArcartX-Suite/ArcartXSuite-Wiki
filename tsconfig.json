{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vitepress/client", "node"]
  },
  "include": ["docs/.vitepress/**/*", "docs/**/*.ts", "docs/**/*.vue"],
  "exclude": ["node_modules"]
}
